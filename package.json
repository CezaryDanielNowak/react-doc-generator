{
  "name": "react-doc-generator-fork",
  "version": "1.7.0-wip",
  "type": "commonjs",
  "description": "Generate a simple React Component documentation in Markdown.",
  "main": "dist/index.js",
  "bin": {
    "react-doc-generator": "dist/react-doc-generator.js"
  },
  "scripts": {
    "lint": "eslint src",
    "transpile": "babel src -D -d dist --ignore '__tests__,__mocks__' --config-file ./babel.config.json",
    "watch": "babel src -D -d dist --ignore '__tests__,__mocks__' --watch --config-file ./babel.config.json",
    "pretest": "npm run transpile",
    "preversion": "npm run lint",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CezaryDanielNowak/react-doc-generator"
  },
  "author": "Marcin Borkowski",
  "license": "MIT",
  "homepage": "https://github.com/marborkowski/react-doc-generator#readme",
  "keywords": [
    "react",
    "react-docgen",
    "markdown",
    "documentation",
    "generator",
    "tool",
    "tools",
    "docgen",
    "readme file",
    "readme",
    "instruction",
    "guide",
    "list of components",
    "components",
    "spa",
    "webpack",
    "engine"
  ],
  "dependencies": {
    "cli-table": "^0.3.11",
    "commander": "9.5.0",
    "handlebars": "^4.7.9",
    "node-dir": "^0.1.17",
    "react-docgen": "^5.4.3"
  },
  "peerDependencies": {
    "prop-types": "16 - 18",
    "react": "16 - 18",
    "react-dom": "16 - 18"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^30.1.2",
    "babel-plugin-minify-simplify": "^0.5.1",

    "eslint": "^8.12.0",
    "eslint-config-react-app": "^7.0.0",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.29.4",
    "jest-cli": "^27.5.1"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "jest": {
    "transform": {
       "^.+\\.js$": "babel-jest"
    },
    "roots": [
      "src"
    ],
    "testRegex": "/__tests__/(.+?).test.js$"
  }
}
